# ─────────────────────────────────────────────
# EduImpact AI Manager v1 — Environment Config
# ─────────────────────────────────────────────

# Django
SECRET_KEY=testsecret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=eduimpact_db
DB_USER=eduimpact_user
DB_PASSWORD=strongpassword
DB_HOST=db
DB_PORT=5432
DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── AI Provider ───────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# OR use Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# AI provider: openai | anthropic
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini

# ─── Facebook ──────────────────────────────
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# ─── X (Twitter) ───────────────────────────
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
X_BEARER_TOKEN=your_x_bearer_token

# ─── News API ──────────────────────────────
NEWS_API_KEY=your_newsapi_org_key

# ─── Media / Storage ───────────────────────
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
# Optional: S3 for image storage
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# ─── Safety ────────────────────────────────
SAFETY_BANNED_WORDS=spam,scam,fake,hate,kill
MAX_DUPLICATE_WINDOW_HOURS=24

# ─── Posting Schedule ──────────────────────
DAILY_POST_LIMIT=10
POST_RETRY_ATTEMPTS=3
